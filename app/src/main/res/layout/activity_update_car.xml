<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:orientation="vertical"
    android:background="@color/border">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        android:background="@color/teal">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif"
            android:text="Update Car Details"
            android:textAlignment="center"
            android:paddingBottom="15dp"
            android:textColor="@color/mainText"
            android:textSize="30sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/image_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/update_car_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircularImageView" />

        <TextView
            android:id="@+id/text_edit_image_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Edit Image"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_text_background" />

    </FrameLayout>


    <EditText
        android:id="@+id/edit_update_make"
        android:layout_width="300dp"
        android:layout_gravity="center"
        android:layout_height="48dp"
        android:hint="Make"
        android:inputType="textCapWords"
        android:textColorHint="@color/secText"
        android:textColor="@color/mainText"/>

    <EditText
        android:id="@+id/edit_update_model"
        android:layout_width="300dp"
        android:layout_gravity="center"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:hint="Model"
        android:inputType="textCapWords"
        android:textColorHint="@color/secText"
        android:textColor="@color/mainText"/>

    <EditText
        android:id="@+id/edit_update_year"
        android:layout_width="300dp"
        android:layout_gravity="center"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:hint="Year"
        android:inputType="number"
        android:textColorHint="@color/secText"
        android:textColor="@color/mainText"/>

    <EditText
        android:id="@+id/edit_update_mileage"
        android:layout_width="300dp"
        android:layout_gravity="center"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:hint="Mileage"
        android:textColorHint="@color/secText"
        android:inputType="number"
        android:textColor="@color/mainText"/>


    <EditText
        android:id="@+id/edit_update_vin"
        android:layout_width="300dp"
        android:layout_gravity="center"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:hint="VIN (optional)"
        android:inputType="textCapCharacters"
        android:textColor="@color/mainText"
        android:textColorHint="@color/secText"/>

</LinearLayout>